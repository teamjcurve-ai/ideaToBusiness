# Prisma - Transaction Pooler (runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Prisma - Direct Connection (migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Supabase JWT ES256 Public Key
SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# CORS (comma-separated)
FRONTEND_URL="https://your-app.vercel.app,http://localhost:3000"

# Server Port
PORT=4001
